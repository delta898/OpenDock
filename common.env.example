# Main domain for this home server stack.
# Default services are published under this domain:
#   blog.example.com
#   n8n.example.com
#   cloud.example.com
#   photos.example.com
#   media.example.com
#   social.example.com
STACK_DOMAIN=example.com

# Default service subdomains.
WORDPRESS_SUBDOMAIN=blog
N8N_SUBDOMAIN=n8n
UPTIME_KUMA_SUBDOMAIN=uptime
HOMEPAGE_SUBDOMAIN=home
NEXTCLOUD_SUBDOMAIN=cloud
IMMICH_SUBDOMAIN=photos
JELLYFIN_SUBDOMAIN=media
MASTODON_SUBDOMAIN=social

# MariaDB administrator password.
# Filled automatically by `make secrets` or before `make up` / `make launch`.
MARIADB_ROOT_PASSWORD=change-root-password

# PostgreSQL administrator account for shared infrastructure.
# POSTGRES_ADMIN_PASSWORD is filled automatically by `make secrets`
# or before `make up` / `make launch`.
POSTGRES_ADMIN_USER=opendock
POSTGRES_ADMIN_PASSWORD=change-postgres-admin-password

# WordPress database user password.
# This should be different from MARIADB_ROOT_PASSWORD.
# Filled automatically by `make secrets` or before WordPress starts.
WORDPRESS_DB_PASSWORD=change-wordpress-db-password

# Nextcloud database user password.
# This should be different from MARIADB_ROOT_PASSWORD.
# Filled automatically by `make secrets` or before Nextcloud starts.
NEXTCLOUD_DB_PASSWORD=change-nextcloud-db-password

# Initial Nextcloud admin password.
# Used only during the first successful Nextcloud installation.
# Filled automatically by `make secrets` or before Nextcloud starts.
# After installation, change the password in Nextcloud or with occ.
NEXTCLOUD_ADMIN_PASSWORD=change-nextcloud-admin-password

# Immich PostgreSQL password.
# Use only A-Z, a-z, and 0-9 for best compatibility with Immich's Docker setup.
# Filled automatically by `make secrets` or before Immich starts.
IMMICH_DB_PASSWORD=changeImmichDbPassword

# Mastodon PostgreSQL password.
# Filled automatically by `make secrets` or before Mastodon starts.
MASTODON_DB_PASSWORD=change-mastodon-db-password

# Mastodon owner account for initial admin setup.
# Fill with `make setup mastodon` or edit manually.
MASTODON_ADMIN_USERNAME=opendock
MASTODON_ADMIN_EMAIL=
MASTODON_ADMIN_PASSWORD=change-mastodon-admin-password

# Mastodon Rails secrets.
# Filled automatically by `make secrets` or before Mastodon starts.
MASTODON_SECRET_KEY_BASE=change-mastodon-secret-key-base
MASTODON_OTP_SECRET=change-mastodon-otp-secret
MASTODON_ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=change-mastodon-active-record-encryption-deterministic-key
MASTODON_ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=change-mastodon-active-record-encryption-key-derivation-salt
MASTODON_ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=change-mastodon-active-record-encryption-primary-key

# Mastodon VAPID keys for web push notifications.
# Filled automatically by `make secrets` or before Mastodon starts.
MASTODON_VAPID_PRIVATE_KEY=change-mastodon-vapid-private-key
MASTODON_VAPID_PUBLIC_KEY=change-mastodon-vapid-public-key
