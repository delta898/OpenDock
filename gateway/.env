CADDY_VERSION=2

HTTP_PORT=80
HTTPS_PORT=443

# If this stack runs on a headless Ubuntu Server, replace localhost with
# the server's internal IP so you can open WordPress from another device.
#
# Check the server IP:
#   hostname -I
#
# Example for first setup:
#   WORDPRESS_DOMAIN=192.168.0.22
#
# Later, when you connect a real domain:
#   WORDPRESS_DOMAIN=blog.example.com
WORDPRESS_DOMAIN=localhost
WORDPRESS_UPSTREAM=wordpress:80
