# Copy this file to .sync.env and edit the values for your test machine.
#
# Target name:
#   make sync-dry-run test
#   make sync test
#
# Variables are named as:
#   SYNC_<TARGET>_REMOTE
#   SYNC_<TARGET>_PATH
#   SYNC_<TARGET>_SSH_PORT
#
# The target name is uppercased, and '-' becomes '_'.
# For example, "make sync test-server" uses SYNC_TEST_SERVER_REMOTE.

SYNC_TEST_REMOTE=user@test-host
SYNC_TEST_PATH=/home/user/DockerPackages

# Optional.
# SYNC_TEST_SSH_PORT=22
